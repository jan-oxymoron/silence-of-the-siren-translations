      </GameDBLocalizedString>
      <GameDBLocalizedString>
        <LocID>OBJECTIVE_CAMPAIGN_CRUSADERS_LVL4_STASH_DONE</LocID>
        <Text><![CDATA[<color=SOTS_COLOR_MOVEMENT>Найди ресурсы 3/3 - ВЫПОЛНЕНО/color>]]></Text>
      </GameDBLocalizedString>
      <GameDBLocalizedString>
        <LocID>OBJECTIVE_CAMPAIGN_CRUSADERS_LVL4_CROSS_BRIDGE</LocID>
